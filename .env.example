# Banco de dados (PostgreSQL via Docker)
DATABASE_URL=postgresql://agrosync:agrosync_secret@localhost:5432/agrosync_db

# Para desenvolvimento local (sem Docker), aponte para sua instância local
# DATABASE_URL=postgresql://postgres:sua_senha@localhost:5432/agro_sync_testes

# JWT - TROQUE ESTE VALOR EM PRODUÇÃO
JWT_SECRET=agrosync_jwt_super_secreto_troque_em_prod

# RabbitMQ
RABBITMQ_URL=amqp://agrosync:rabbit_secret@localhost:5672

# DeepSeek AI
DEEPSEEK_API_KEY=sua_chave_aqui

# Portas dos serviços (opcional — o docker-compose já define)
PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
GARDEN_SERVICE_URL=http://localhost:3002
SUPPLY_SERVICE_URL=http://localhost:3003
TASK_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3005
